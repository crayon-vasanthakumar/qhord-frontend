PORT=4000
NODE_ENV=development

# Public URL of this backend service (used to build Google OAuth redirect_uri)
# Production (Render): https://qhord.seenode.app  ← point to frontend proxy domain
# Docker self-hosted:  http://localhost:4000
BACKEND_URL=http://localhost:4000

# Public URL of the frontend (used to redirect after OAuth callback)
# Production: https://qhord.seenode.app
FRONTEND_URL=http://localhost:3000

# Google OAuth — leave blank for mock dev flow
# Production values go in Render dashboard, NOT here
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# PostgreSQL connection
DATABASE_URL=postgres://postgres:postgres@postgres:5432/control_tower

# Authentication
JWT_SECRET=replace-with-strong-jwt-secret
BCRYPT_SALT_ROUNDS=12

# Encryption key for API keys (32+ chars recommended)
ENCRYPTION_SECRET=replace-with-strong-encryption-secret

# External tool base URLs (customize per environment)
APOLLO_BASE_URL=https://api.apollo.io
# Optional: synced into ClientToolAccount for Apollo (live search when set)
APOLLO_API_KEY=

# Free demo stack (auto when both keys set): maps Apollo→Hunter, Clay→Hunter, Smartlead→Brevo
# Set to false to disable remapping even if keys exist
QHORD_USE_FREE_DEMO_STACK=auto
HUNTER_API_KEY=
HUNTER_MAX_DOMAINS=5
BREVO_API_KEY=
BREVO_SENDER_EMAIL=
BREVO_SENDER_NAME=Qhord
BREVO_BASE_URL=https://api.brevo.com/v3
# Run pipeline immediately in API request (recommended for free Hunter/Brevo demo)
QHORD_SYNC_PIPELINE=true
CLAY_BASE_URL=https://api.clay.run
HEYREACH_BASE_URL=https://api.heyreach.io
SMARTLY_BASE_URL=https://api.smartly.io

# BetterContacts (contact enrichment) — https://bettercontact.rocks
BETTERCONTACTS_API_KEY=
# Calendly (scheduling) — PAT from https://developer.calendly.com
CALENDLY_API_KEY=
# Calendly OAuth (for multi-user connections, optional)
CALENDLY_CLIENT_ID=
CALENDLY_CLIENT_SECRET=
CALENDLY_WEBHOOK_SECRET=

# Redis connection for BullMQ queue system
REDIS_URL=rediss://default:gQAAAAAAAc9BAAIgcDE5OTI4MWE2NGNlNzk0NWUyOGMyNmNjZjA0NTk4NTQ2MQ@enhanced-oriole-118593.upstash.io:6379

# Execution mode:
# - mock: always simulate tool API execution
# - live: always call real tool APIs
# - auto: live when API key exists, otherwise mock fallback
EXECUTION_MODE=auto
